{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-beads"],
  "lsp": {
    "gopls": {
      "command": ["gopls", "-remote=auto"]
    }
  },
  "mcp": {
    "gremlin": {
      "type": "local",
      "command": ["gremlin-mcp"],
      "environment": {
        "GREMLIN_URL": "ws://localhost:8182/gremlin"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_KEY}"
      },
      "enabled": true
    },
    "mcp-atlassian": {
      "type": "local",
      "command": ["uvx", "--with", "packaging", "mcp-atlassian"],
      "environment": {
        "JIRA_URL": "https://hashicorp.atlassian.net",
        "JIRA_USERNAME": "John.Maguire3@ibm.com",
        "JIRA_API_TOKEN": "{env:JIRA_TOKEN}"
      }
    }
  },
  "agent": {
    "superPlan": {
      "description": "Planning orchestrator that gathers three independent plans, iterates on blocking questions, and synthesizes one recommended plan with tradeoffs for each planner",
      "mode": "primary",
      "model": "github-copilot/gpt-5.4",
      "temperature": 0.2,
      "steps": 12,
      "prompt": "{file:./prompts/superplan-orchestrator.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "webfetch": false,
        "task": true
      },
      "permission": {
        "task": {
          "*": "deny",
          "superPlan-gpt54": "allow",
          "superPlan-gemini31": "allow",
          "superPlan-gpt53codex": "allow"
        }
      }
    },
    "superPlan-gpt54": {
      "description": "Independent planning subagent for superPlan using GPT-5.4",
      "mode": "subagent",
      "hidden": true,
      "model": "github-copilot/gpt-5.4",
      "temperature": 0.2,
      "steps": 8,
      "prompt": "{file:./prompts/superplan-planner.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "webfetch": false,
        "task": false
      }
    },
    "superPlan-gemini31": {
      "description": "Independent planning subagent for superPlan using Gemini 3.1 Pro Preview",
      "mode": "subagent",
      "hidden": true,
      "model": "github-copilot/gemini-3.1-pro-preview",
      "temperature": 0.2,
      "steps": 8,
      "prompt": "{file:./prompts/superplan-planner.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "webfetch": false,
        "task": false
      }
    },
    "superPlan-gpt53codex": {
      "description": "Independent planning subagent for superPlan using GPT-5.3 Codex",
      "mode": "subagent",
      "hidden": true,
      "model": "github-copilot/gpt-5.3-codex",
      "temperature": 0.2,
      "steps": 8,
      "prompt": "{file:./prompts/superplan-planner.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "webfetch": false,
        "task": false
      }
    }
  },
  "tools": {
    "skill": true
  }
}
