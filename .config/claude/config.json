{
  "mcpServers": {
    "gremlin": {
      "command": "gremlin-mcp",
      "args": [],
      "env": {
        "GREMLIN_URL": "ws://localhost:8182/gremlin"
      }
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "transport": "sse",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_KEY}"
      }
    },
    "mcp-atlassian": {
      "command": "uvx",
      "args": ["mcp-atlassian"],
      "env": {
        "JIRA_URL": "https://hashicorp.atlassian.net",
        "JIRA_USERNAME": "John.Maguire3@ibm.com",
        "JIRA_API_TOKEN": "${JIRA_TOKEN}"
      }
    }
  },
  "lspServers": {
    "gopls": {
      "command": "gopls",
      "args": ["-remote=auto"]
    }
  }
}
